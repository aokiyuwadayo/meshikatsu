# OpenAI GPT-4o Vision API（レシート読み取り /receipt で使用：サーバ版のみ）
# https://platform.openai.com/api-keys で取得して .env.local にコピーする
OPENAI_API_KEY=sk-xxxxxxxxxx

# 共有フィード（Supabase）— 設定すると「本物の共有フィード」になる。
# 取得手順: docs/db/FEED-DB-SETUP.md / anon キーは公開前提（RLSで保護）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
